rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users collection: needs to be readable to find managers/employees for login
    match /users/{userId} {
      allow read: if true;
      allow write: if true;
    }
    
    // Transactions, Expenses, POS Terminals: allowing all for now to ensure persistence
    match /transactions/{id} {
      allow read, write: if true;
    }
    match /expenses/{id} {
      allow read, write: if true;
    }
    match /pos_terminals/{id} {
      allow read, write: if true;
    }
    match /test_connection/{id} {
      allow read: if true;
    }
    
    // Default fallback
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
