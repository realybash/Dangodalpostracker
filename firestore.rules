rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // --- BorrowKeep Collection Rules ---
    match /borrowKeep/{transactionId} {
      allow get: if isSignedIn() && existing().ownerId == request.auth.uid;
      allow list: if isSignedIn();
      allow create: if isSignedIn() &&
                       isValidId(transactionId) &&
                       isValidBorrowKeepTransaction(incoming()) &&
                       incoming().ownerId == request.auth.uid;
      allow update: if isSignedIn() &&
                       isValidId(transactionId) &&
                       isValidBorrowKeepTransaction(incoming()) &&
                       existing().ownerId == request.auth.uid &&
                       incoming().ownerId == request.auth.uid &&
                       incoming().id == existing().id;
      allow delete: if isSignedIn() && existing().ownerId == request.auth.uid;
    }

    // 1. Global safety net catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Global Helper Primitives ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isOwner(data) {
      return isSignedIn() && data.ownerId == request.auth.uid;
    }

    // --- Entity Specific Security Blueprints ---
    function isValidUser(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.name is string && data.name.size() <= 100 &&
             data.role is string && (data.role == 'Manager' || data.role == 'Employee') &&
             (!('pin' in data) || (data.pin is string && data.pin.size() == 4)) &&
             (!('phone' in data) || (data.phone is string && data.phone.size() <= 30)) &&
             data.ownerId is string && data.ownerId.size() <= 128 &&
             (!('activated' in data) || data.activated is bool) &&
             (!('email' in data) || (data.email is string && data.email.size() <= 150)) &&
             (!('password' in data) || (data.password is string && data.password.size() <= 100));
    }

    function isValidTransaction(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.employeeId is string && data.employeeId.size() <= 128 &&
             data.employeeName is string && data.employeeName.size() <= 100 &&
             data.type is string && (data.type == 'Deposit' || data.type == 'Withdrawal' || data.type == 'Transfer') &&
             data.provider is string && (data.provider == 'OPay' || data.provider == 'Moniepoint' || data.provider == 'PalmPay' || data.provider == 'Others') &&
             data.amount is number && data.amount >= 0 && data.amount <= 1000000000 &&
             data.customerFee is number && data.customerFee >= 0 &&
             data.terminalFee is number && data.terminalFee >= 0 &&
             data.profit is number &&
             data.timestamp is string && data.timestamp.size() <= 50 &&
             data.ownerId is string && data.ownerId.size() <= 128 &&
             (!('notes' in data) || (data.notes is string && data.notes.size() <= 1000)) &&
             (!('customerPhone' in data) || (data.customerPhone is string && data.customerPhone.size() <= 50)) &&
             (!('status' in data) || (data.status is string && (data.status == 'Success' || data.status == 'Failed' || data.status == 'Pending'))) &&
             (!('subType' in data) || (data.subType is string && data.subType.size() <= 100)) &&
             (!('feeMethod' in data) || (data.feeMethod is string && (data.feeMethod == 'CardDebit' || data.feeMethod == 'Cash'))) &&
             (!('totalCustomerCharged' in data) || (data.totalCustomerCharged is number && data.totalCustomerCharged >= 0)) &&
             (!('cbnCharge' in data) || (data.cbnCharge is number && data.cbnCharge >= 0)) &&
             (!('chargesStatus' in data) || (data.chargesStatus is string && (data.chargesStatus == 'Paid' || data.chargesStatus == 'Unpaid'))) &&
            (!('customerName' in data) || (data.customerName is string && data.customerName.size() <= 150)) &&
            (!('unpaidFeeAmount' in data) || (data.unpaidFeeAmount is number && data.unpaidFeeAmount >= 0)) &&
            (!('terminalId' in data) || (data.terminalId is string && data.terminalId.size() <= 128)) &&
            (!('terminalName' in data) || (data.terminalName is string && data.terminalName.size() <= 100));
    }

    function isValidPosTerminal(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.name is string && data.name.size() <= 100 &&
             data.provider is string && data.provider.size() <= 100 &&
             (!('serialNumber' in data) || (data.serialNumber is string && data.serialNumber.size() <= 100)) &&
             (!('terminalFeeRate' in data) || data.terminalFeeRate is number) &&
             data.ownerId is string && data.ownerId.size() <= 128 &&
             (!('employeeId' in data) || (data.employeeId is string && data.employeeId.size() <= 128)) &&
             (!('employeeName' in data) || (data.employeeName is string && data.employeeName.size() <= 100)) &&
             (!('posAccountNo' in data) || (data.posAccountNo is string && data.posAccountNo.size() <= 100)) &&
             (!('cashierName' in data) || (data.cashierName is string && data.cashierName.size() <= 100)) &&
             (!('areaOfWorking' in data) || (data.areaOfWorking is string && data.areaOfWorking.size() <= 150)) &&
             data.addedBy is string && data.addedBy.size() <= 100 &&
             data.status is string && (data.status == 'Active' || data.status == 'Inactive') &&
             data.timestamp is string && data.timestamp.size() <= 50;
    }

    function isValidBorrowKeepTransaction(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.name is string && data.name.size() <= 100 &&
             data.amount is number && data.amount >= 0 &&
             data.type is string && (data.type == 'loan_given' || data.type == 'loan_repaid' || data.type == 'money_kept' || data.type == 'money_returned') &&
             data.timestamp is string && data.timestamp.size() <= 50 &&
             (!('ownerId' in data) || (data.ownerId is string && data.ownerId.size() <= 128)) &&
             (!('employeeId' in data) || (data.employeeId is string && data.employeeId.size() <= 128)) &&
             (!('employeeName' in data) || (data.employeeName is string && data.employeeName.size() <= 100)) &&
             (!('linkedTransactionId' in data) || (data.linkedTransactionId is string && data.linkedTransactionId.size() <= 128)) &&
             (!('repaidAmount' in data) || (data.repaidAmount is number && data.repaidAmount >= 0)) &&
             (!('status' in data) || (data.status is string && (data.status == 'pending' || data.status == 'partial' || data.status == 'settled'))) &&
             (!('notes' in data) || (data.notes is string && data.notes.size() <= 1000)) &&
             (!('photoFront' in data) || (data.photoFront is string && data.photoFront.size() <= 1000000)) &&
             (!('photoBack' in data) || (data.photoBack is string && data.photoBack.size() <= 1000000)) &&
             (!('photo' in data) || (data.photo is string && data.photo.size() <= 1000000));
    }

    // --- Users Collection Rules ---
    match /users/{userId} {
      allow get: if isSignedIn() && (userId == request.auth.uid || resource.data.ownerId == request.auth.uid);
      allow list: if isSignedIn();
      
      allow create: if isSignedIn() && incoming().ownerId == request.auth.uid;
                       
      allow update: if isSignedIn() &&
                       incoming().ownerId == request.auth.uid &&
                        existing().ownerId == request.auth.uid &&
                       incoming().id == existing().id;
                       
      allow delete: if isSignedIn() && existing().ownerId == request.auth.uid;
    }

    // --- Transactions Collection Rules ---
    match /transactions/{transactionId} {
      allow get: if isSignedIn() && existing().ownerId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.ownerId;
      allow list: if isSignedIn();
      
      allow create: if isSignedIn() &&
                       isValidId(transactionId) &&
                       isValidTransaction(incoming()) &&
                       incoming().ownerId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.ownerId;
                       
      allow update: if isSignedIn() &&
                       isValidId(transactionId) &&
                       isValidTransaction(incoming()) &&
                       existing().ownerId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.ownerId &&
                       incoming().ownerId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.ownerId &&
                       incoming().id == existing().id;
                       
      allow delete: if isSignedIn() && existing().ownerId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.ownerId;
    }

    // --- POS Terminals Collection Rules ---
    match /pos_terminals/{terminalId} {
      allow get: if isSignedIn() && existing().ownerId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.ownerId;
      allow list: if isSignedIn();
      
      allow create: if isSignedIn() &&
                       isValidId(terminalId) &&
                       isValidPosTerminal(incoming()) &&
                       incoming().ownerId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.ownerId;
                       
      allow update: if isSignedIn() &&
                       isValidId(terminalId) &&
                       isValidPosTerminal(incoming()) &&
                       existing().ownerId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.ownerId &&
                       incoming().ownerId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.ownerId &&
                       incoming().id == existing().id;
                       
      allow delete: if isSignedIn() && existing().ownerId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.ownerId;
    }

    // --- Connection Verification Rules ---
    match /test_connection/{documentId} {
      allow get: if true;
    }
  }
}
