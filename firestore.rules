rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is a manager
    function isManager() {
      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Manager';
    }

    // Users collection
    match /users/{userId} {
      // Allow read if authenticated. List is restricted to managers.
      allow get: if request.auth != null;
      allow list: if isManager();
      
      // Only managers can create/update other users. Users can update their own PIN.
      allow create: if isManager();
      allow update: if request.auth != null && (
        (request.auth.uid == userId && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['pin'])) ||
        isManager()
      );
      allow delete: if isManager();
    }
    
    // Settings collection
    match /settings/{ownerId} {
      // Managers can read/write their own settings.
      // Employees can read their manager's settings if they are linked.
      allow read: if request.auth != null && (
        request.auth.uid == ownerId || 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.ownerId == ownerId
      );
      allow write: if request.auth != null && request.auth.uid == ownerId && isManager();
    }

    // Borrow/Keep records
    match /borrowKeep/{id} {
      allow read, write: if request.auth != null && (
        resource == null || 
        resource.data.ownerId == request.auth.uid || 
        resource.data.cashierId == request.auth.uid ||
        isManager()
      );
    }
    
    // Transactions: Isolation between cashiers and owners
    match /transactions/{id} {
      allow read: if request.auth != null && (
        resource.data.ownerId == request.auth.uid || 
        resource.data.cashierId == request.auth.uid
      );
      allow create: if request.auth != null && (
        request.resource.data.cashierId == request.auth.uid ||
        request.resource.data.ownerId == request.auth.uid
      );
      allow update, delete: if request.auth != null && (
        resource.data.ownerId == request.auth.uid || 
        resource.data.cashierId == request.auth.uid
      );
    }

    // Expenses
    match /expenses/{id} {
      allow read: if request.auth != null && (
        resource.data.ownerId == request.auth.uid || 
        resource.data.employeeId == request.auth.uid
      );
      allow create: if request.auth != null && (
        request.resource.data.employeeId == request.auth.uid ||
        request.resource.data.ownerId == request.auth.uid
      );
      allow update, delete: if request.auth != null && (
        resource.data.ownerId == request.auth.uid || 
        resource.data.employeeId == request.auth.uid
      );
    }

    // POS Terminals
    match /pos_terminals/{id} {
      allow read: if request.auth != null && (
        resource.data.ownerId == request.auth.uid || 
        resource.data.employeeId == request.auth.uid
      );
      allow create: if request.auth != null && (
        request.resource.data.ownerId == request.auth.uid
      );
      allow update: if request.auth != null && (
        resource.data.ownerId == request.auth.uid || 
        resource.data.employeeId == request.auth.uid
      );
      allow delete: if request.auth != null && (
        resource.data.ownerId == request.auth.uid
      );
    }
    
    // Pricing Rules
    match /pricing_rules/{id} {
      allow read: if request.auth != null;
      allow write: if isManager();
    }

    match /test_connection/{id} {
      allow read: if true;
    }
  }
}
