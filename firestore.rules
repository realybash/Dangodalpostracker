rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is a manager
    function isManager() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Manager';
    }

    // Users collection
    match /users/{userId} {
      // Allow read for everyone to facilitate login lookup (Phone -> Profile)
      allow get, list: if true;
      
      // Allow writing if authenticated
      allow write: if request.auth != null;
    }
    
    // Transactions: Isolation between cashiers
    match /transactions/{id} {
      allow read, write: if request.auth != null;
    }

    // Expenses
    match /expenses/{id} {
      allow read, write: if request.auth != null;
    }

    // POS Terminals
    match /pos_terminals/{id} {
      allow read, write: if request.auth != null;
    }

    match /test_connection/{id} {
      allow read: if true;
    }
  }
}
