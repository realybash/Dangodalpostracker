rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Catch-all safety net - very first rule block inside match
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper function to check if user is a manager
    function isManager() {
      return request.auth != null && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Manager';
    }

    // Helper to check if the user is an employee under the specified owner
    function isEmployeeOf(ownerId) {
      return request.auth != null && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.ownerId == ownerId;
    }

    // Helper to check if the user is either the owner or an employee of that owner
    function isOwnerOrEmployee(ownerId) {
      return request.auth != null && (
        request.auth.uid == ownerId || 
        isEmployeeOf(ownerId)
      );
    }

    // Users collection
    match /users/{userId} {
      // Allow get/list publicly to support local lookup/matching prior to active session authentication.
      allow get, list: if true;
      
      // Only managers can create/update other users' documents belonging to their franchise. Users can update their own profile/PIN.
      allow create: if request.auth != null && (request.auth.uid == userId || (request.resource.data.ownerId == request.auth.uid && isManager()));
      allow update: if request.auth != null && (request.auth.uid == userId || (resource.data.ownerId == request.auth.uid && isManager()));
      allow delete: if request.auth != null && (resource.data.ownerId == request.auth.uid && isManager());
    }
    
    // Users sync (legacy or auxiliary match)
    match /users_sync/{id} {
      allow read: if true;
    }

    // Settings collection
    match /settings/{ownerId} {
      // Managers can read/write their own settings.
      // Employees can read their manager's settings if they are linked.
      allow read: if request.auth != null && (request.auth.uid == ownerId || isEmployeeOf(ownerId));
      allow write: if request.auth != null && request.auth.uid == ownerId && isManager();
    }

    // Borrow/Keep records
    match /borrowKeep/{id} {
      allow read: if request.auth != null && (
        resource.data.ownerId == request.auth.uid || 
        isEmployeeOf(resource.data.ownerId)
      );
      allow create: if request.auth != null && (
        request.resource.data.ownerId == request.auth.uid ||
        isEmployeeOf(request.resource.data.ownerId)
      );
      allow update: if request.auth != null && (
        resource.data.ownerId == request.auth.uid || 
        isEmployeeOf(resource.data.ownerId)
      );
      allow delete: if request.auth != null && (
        resource.data.ownerId == request.auth.uid
      );
    }
    
    // Transactions: Isolation between cashiers and owners
    match /transactions/{id} {
      allow read: if request.auth != null && (
        resource.data.ownerId == request.auth.uid || 
        resource.data.cashierId == request.auth.uid ||
        (request.auth.uid == 'JcC1krC85wXQidNcL8no2NEJc4v1' && (resource.data.ownerId == 'mgr_1' || resource.data.ownerId == 'local_owner'))
      );
      allow create: if request.auth != null && (
        request.resource.data.cashierId == request.auth.uid ||
        request.resource.data.ownerId == request.auth.uid
      );
      allow update, delete: if request.auth != null && (
        resource.data.ownerId == request.auth.uid || 
        resource.data.cashierId == request.auth.uid
      );
    }

    // Expenses
    match /expenses/{id} {
      allow read: if request.auth != null && (
        resource.data.ownerId == request.auth.uid || 
        resource.data.employeeId == request.auth.uid
      );
      allow create: if request.auth != null && (
        request.resource.data.employeeId == request.auth.uid ||
        request.resource.data.ownerId == request.auth.uid
      );
      allow update, delete: if request.auth != null && (
        resource.data.ownerId == request.auth.uid || 
        resource.data.employeeId == request.auth.uid
      );
    }

    // POS Terminals
    match /pos_terminals/{id} {
      allow read: if request.auth != null && (
        resource.data.ownerId == request.auth.uid || 
        resource.data.employeeId == request.auth.uid ||
        isEmployeeOf(resource.data.ownerId)
      );
      // ONLY the owner/manager can create or delete terminals
      allow create: if request.auth != null && (
        request.resource.data.ownerId == request.auth.uid && isManager()
      );
      allow update: if request.auth != null && (
        resource.data.ownerId == request.auth.uid || 
        resource.data.employeeId == request.auth.uid ||
        isEmployeeOf(resource.data.ownerId)
      );
      allow delete: if request.auth != null && (
        resource.data.ownerId == request.auth.uid && isManager()
      );
    }
    
    // Pricing Rules
    match /pricing_rules/{id} {
      allow read: if request.auth != null;
      allow write: if isManager();
    }

    match /test_connection/{id} {
      allow read: if true;
    }
  }
}
