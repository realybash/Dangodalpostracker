{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User account details and roles",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Full name" },
        "role": { "type": "string", "enum": ["Manager", "Employee"], "description": "User role" },
        "phone": { "type": "string", "description": "Unique phone number used for login" },
        "ownerId": { "type": "string", "description": "ID of the manager who owns this employee account" },
        "activated": { "type": "boolean", "description": "Whether the account is active" },
        "pin": { "type": "string", "description": "Numeric PIN for secure operations" }
      },
      "required": ["name", "role", "phone", "activated"]
    },
    "Transaction": {
      "title": "Financial Transaction",
      "description": "Records of cash-in, cash-out, and transfers",
      "type": "object",
      "properties": {
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["Withdrawal", "Deposit", "Transfer", "Airtime", "Bill Payment"] },
        "status": { "type": "string", "enum": ["Success", "Pending", "Failed"] },
        "ownerId": { "type": "string" },
        "cashierId": { "type": "string" },
        "provider": { "type": "string" },
        "customerFee": { "type": "number" },
        "terminalFee": { "type": "number" },
        "cbnCharge": { "type": "number" },
        "profit": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["amount", "type", "status", "ownerId", "cashierId", "timestamp"]
    },
    "Expense": {
      "title": "Business Expense",
      "description": "Operational costs recorded by employees or managers",
      "type": "object",
      "properties": {
        "amount": { "type": "number" },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "ownerId": { "type": "string" },
        "employeeId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["amount", "category", "ownerId", "employeeId", "timestamp"]
    },
    "PosTerminal": {
      "title": "POS Terminal",
      "description": "Configuration and tracking for physical terminals",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "provider": { "type": "string" },
        "employeeId": { "type": "string" },
        "ownerId": { "type": "string" },
        "serialNumber": { "type": "string" }
      },
      "required": ["name", "provider", "ownerId"]
    },
    "Settings": {
      "title": "Application Settings",
      "description": "Global charge rules and regulatory configurations",
      "type": "object",
      "properties": {
        "providerConfigs": { "type": "array" },
        "regulatoryConfig": { "type": "object" },
        "lastUpdated": { "type": "string", "format": "date-time" }
      }
    },
    "BorrowKeep": {
      "title": "Borrow/Keep Records",
      "description": "Records of money borrowed or kept from transactions",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["Borrow", "Keep"] },
        "amount": { "type": "number" },
        "person": { "type": "string" },
        "ownerId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "amount", "person", "ownerId", "timestamp"]
    },
    "PricingRule": {
      "title": "Pricing Rule",
      "description": "Advanced versioned pricing rule",
      "type": "object",
      "properties": {
        "provider": { "type": "string" },
        "type": { "type": "string" },
        "minAmount": { "type": "number" },
        "maxAmount": { "type": "number" },
        "customerCharge": { "type": "number" },
        "customerChargeType": { "type": "string", "enum": ["flat", "percent"] },
        "providerCharge": { "type": "number" },
        "providerChargeType": { "type": "string", "enum": ["flat", "percent"] },
        "regulatoryCharge": { "type": "number" },
        "vatRate": { "type": "number" },
        "effectiveDate": { "type": "string", "format": "date-time" },
        "expiryDate": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["active", "inactive", "archived"] },
        "version": { "type": "number" },
        "createdBy": { "type": "string" },
        "updatedBy": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "ownerId": { "type": "string" }
      },
      "required": ["provider", "type", "minAmount", "maxAmount", "customerCharge", "status", "version", "ownerId"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/transactions/{id}": {
      "schema": "Transaction",
      "description": "Financial logs"
    },
    "/expenses/{id}": {
      "schema": "Expense",
      "description": "Expense logs"
    },
    "/pos_terminals/{id}": {
      "schema": "PosTerminal",
      "description": "Terminal records"
    },
    "/settings/{ownerId}": {
      "schema": "Settings",
      "description": "Global config per manager"
    },
    "/borrowKeep/{id}": {
      "schema": "BorrowKeep",
      "description": "Debt and credit tracking"
    },
    "/pricing_rules/{id}": {
      "schema": "PricingRule",
      "description": "Advanced pricing rules"
    }
  }
}
